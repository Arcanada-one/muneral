# Muneral API — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env

# App
NODE_ENV=production
PORT=3500

# Database (Arcana DB server)
DATABASE_URL=postgresql://muneral_app:CHANGE_ME@135.181.222.38:5432/arcanada_muneral

# Redis (Arcana DB server)
REDIS_URL=redis://:CHANGE_ME@135.181.222.38:6379
REDIS_PREFIX=muneral:

# JWT
JWT_SECRET=CHANGE_ME_AT_LEAST_64_CHARS
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# GitHub OAuth (create at github.com/organizations/Arcanada-one/settings/applications)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://api.muneral.com/auth/github/callback

# Telegram Bot (create via @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# API Key prefix (informational, used in key generation)
API_KEY_PREFIX=mun_sk_

# Muneral Web URL (for CORS)
WEB_URL=https://app.muneral.com

# Rate limiting
RATE_LIMIT_AUTH_PER_MIN=5
RATE_LIMIT_API_PER_SEC=30
